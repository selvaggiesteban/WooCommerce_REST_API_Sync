{
    "name": "selvaggiesteban/wc-api-sync",
    "description": "High-performance bidirectional sync for all WooCommerce domains",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Esteban Selvaggi",
            "email": "selvaggi.esteban@gmail.com",
            "homepage": "https://selvaggiesteban.dev"
        }
    ],
    "require": {
        "php": ">=7.4",
        "yahnis-elsts/plugin-update-checker": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "phpcompatibility/phpcompatibility-wp": "*",
        "wp-coding-standards/wpcs": "*"
    },
    "autoload": {
        "psr-4": {
            "WooCommerceApiSync\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WooCommerceApiSync\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs",
        "lint:fix": "phpcbf"
    },
    "extra": {
        "wordpress-plugin": {
            "name": "WooCommerce REST API Sync",
            "slug": "wc-api-sync",
            "version": "1.0.0"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
